# PARAMETERS
# ============================================================
RP_MAX_POINTS    = 50_000   # downsample RP only
N_GRID_POINTS    = 500      # DC voltage grid resolution for cycle averaging
SMOOTH_WINDOW    = 51       # Savitzky-Golay window for cycle-avg line
RAW_DS           = 5        # downsample factor for scatter plots
DC_FILTER_ORDER  = 3        # Butterworth filter for DC ramp direction detection
